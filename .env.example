DEMO_NAME=text-diffusion-lab
DEMO_MODE=development

FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=3300

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8300
BACKEND_URL=http://127.0.0.1:8300

MODEL_ADAPTER_URL=http://127.0.0.1:8600
MODEL_ADAPTER_HOST=127.0.0.1
MODEL_ADAPTER_PORT=8600
MODEL_ADAPTER_TIMEOUT_MS=30000
MODEL_WORKER_TIMEOUT_MS=300000
MODEL_PRELOAD=0
MODEL_PRELOAD_TIMEOUT_MS=600000

MODEL_PROVIDER=auto

# Native ModelDeck text-diffusion gateway. Set MODEL_PROVIDER=modeldeck to
# force this provider. ModelDeck must already be running.
MODELDECK_BASE_URL=http://127.0.0.1:8600
MODELDECK_MODEL=text-diffusion-q4
MODELDECK_TIMEOUT_SECONDS=60
MODELDECK_POLL_INTERVAL_MS=250
DIFFUSIONGEMMA_ENGINE=auto
DIFFUSIONGEMMA_MODEL=google/diffusiongemma-26B-A4B-it

# Optional Red Hat quant model experiment. Start vLLM separately, then set
# MODEL_PROVIDER=redhat-vllm to force this provider.
# REDHAT_VLLM_BASE_URL=http://127.0.0.1:8000/v1
# REDHAT_VLLM_MODEL=RedHatAI/gemma-4-26B-A4B-it-FP8-Dynamic
# REDHAT_VLLM_API_KEY=EMPTY

# Optional override. Leave unset to use the OS-specific project venv default:
# macOS/Linux: .venv-diffusiongemma/bin/python
# Windows: .venv-diffusiongemma\Scripts\python.exe
# DIFFUSIONGEMMA_PYTHON=.venv-diffusiongemma/bin/python

REPLAY_SERVICE_URL=http://127.0.0.1:8700
